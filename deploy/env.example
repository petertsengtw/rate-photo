# Copy to /opt/photo-contest/.env on the server.
#
# PHOTO_CONTEST_SECURE_COOKIES=0 is ONLY for the temporary window before
# HTTPS is set up (e.g. serving plain http://<ip>:8000 before a domain +
# certbot/Caddy cert exists). Session/CSRF cookies with Secure=1 will not be
# sent by browsers over plain HTTP, which would otherwise break login.
#
# Once HTTPS is live, delete this line (or set it to 1) and restart:
#   sudo systemctl restart photo-contest
PHOTO_CONTEST_SECURE_COOKIES=0
